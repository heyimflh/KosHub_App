<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="KosHub_PSDKU"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KosHub">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KosHub.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.KosHub" />

        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.KosHub"
            android:windowSoftInputMode="adjustResize">
        </activity>

        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.KosHub"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".StudentHomeActivity"
            android:theme="@style/Theme.KosHub"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".PropertyDetailBookingActivity"
            android:theme="@style/Theme.KosHub" />

        <activity
            android:name=".MapViewRouteNavigationActivity"
            android:theme="@style/Theme.KosHub" />

        <activity
            android:name=".WaitingListQueueActivity"
            android:theme="@style/Theme.KosHub" />

        <activity
            android:name=".RentalHistoryActivity"
            android:label="Riwayat Sewa"
            android:theme="@style/Theme.KosHub" />

        <activity
            android:name=".ProfileHistoryActivity"
            android:label="Profile"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".FavoriteListActivity"
            android:label="Kos Favorit"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".HelpFaqActivity"
            android:label="Pusat Bantuan"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerDashboardActivity"
            android:label="Owner Dashboard"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerFinanceReportActivity"
            android:label="Finance Report"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerManagementActivity"
            android:label="Manajemen Kos"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerProfileSettingsActivity"
            android:label="Owner Profile"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerBookingActivity"
            android:label="Booking Masuk"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerWithdrawActivity"
            android:label="Tarik Saldo"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerComplaintActivity"
            android:label="Laporan Komplain"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerChatActivity"
            android:label="Inbox Chat"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".OwnerChatRoomActivity"
            android:label="Chat Room"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".TenantComplaintFormActivity"
            android:label="Laporkan Komplain"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".ReviewFormActivity"
            android:label="Beri Ulasan"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".NotificationActivity"
            android:label="Notifikasi"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <service
            android:name=".services.KosHubMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="koshub_general" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_logo_koshub" />

    </application>

</manifest>