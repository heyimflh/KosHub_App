<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_screen"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/logo_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/logo_margin_bottom"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_logo_koshub" />

        <!-- Label "DAFTAR SEBAGAI" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/label_margin_bottom"
            android:letterSpacing="0.08"
            android:text="@string/register_label"
            android:textAllCaps="true"
            android:textColor="@color/text_label"
            android:textSize="@dimen/label_size"
            android:fontFamily="sans-serif-medium" />

        <!-- Role Toggle Container -->
        <FrameLayout
            android:id="@+id/toggleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/toggle_section_margin_bottom"
            android:background="@drawable/bg_toggle_container"
            android:padding="@dimen/toggle_padding">

            <!-- Sliding Indicator -->
            <View
                android:id="@+id/viewRoleIndicator"
                android:layout_width="0dp"
                android:layout_height="@dimen/toggle_height"
                android:background="@drawable/bg_toggle_selector" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Mahasiswa Tab -->
                <TextView
                    android:id="@+id/btnRoleMahasiswa"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/toggle_height"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:drawableStart="@drawable/ic_school"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/text_white"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/role_mahasiswa"
                    android:textColor="@color/text_white"
                    android:textSize="13sp" />

                <!-- Mitra / Owner Tab -->
                <TextView
                    android:id="@+id/btnRoleOwner"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/toggle_height"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:drawableStart="@drawable/ic_domain"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/toggle_inactive_text"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/role_owner"
                    android:textColor="@color/toggle_inactive_text"
                    android:textSize="13sp" />

            </LinearLayout>
        </FrameLayout>

        <!-- Heading -->
        <TextView
            android:id="@+id/tvRegisterTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:text="@string/register_title_mahasiswa"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/heading_size"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvRegisterSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/heading_margin_bottom"
            android:fontFamily="sans-serif"
            android:lineSpacingMultiplier="1.4"
            android:text="@string/register_subtitle_mahasiswa"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/subtitle_size" />

        <!-- Name Input -->
        <LinearLayout
            android:id="@+id/inputNameContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginBottom="@dimen/input_gap"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/input_padding_horizontal"
            android:paddingEnd="@dimen/input_padding_horizontal">

            <ImageView
                android:layout_width="@dimen/input_icon_size"
                android:layout_height="@dimen/input_icon_size"
                android:contentDescription="@string/hint_name"
                android:src="@drawable/ic_profile_person" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_name"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/placeholder_text"
                android:textSize="@dimen/input_text_size" />

        </LinearLayout>

        <!-- Email Input -->
        <LinearLayout
            android:id="@+id/inputEmailContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginBottom="@dimen/input_gap"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/input_padding_horizontal"
            android:paddingEnd="@dimen/input_padding_horizontal">

            <ImageView
                android:layout_width="@dimen/input_icon_size"
                android:layout_height="@dimen/input_icon_size"
                android:contentDescription="Email icon"
                android:src="@drawable/ic_email" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/placeholder_text"
                android:textSize="@dimen/input_text_size" />

        </LinearLayout>

        <!-- Phone Input -->
        <LinearLayout
            android:id="@+id/inputPhoneContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginBottom="@dimen/input_gap"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/input_padding_horizontal"
            android:paddingEnd="@dimen/input_padding_horizontal">

            <ImageView
                android:layout_width="@dimen/input_icon_size"
                android:layout_height="@dimen/input_icon_size"
                android:contentDescription="@string/hint_phone"
                android:src="@drawable/ic_waiting_phone" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_phone"
                android:inputType="phone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/placeholder_text"
                android:textSize="@dimen/input_text_size" />

        </LinearLayout>

        <!-- Password Input -->
        <LinearLayout
            android:id="@+id/inputPasswordContainer"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/input_padding_horizontal"
            android:paddingEnd="@dimen/input_padding_horizontal">

            <ImageView
                android:layout_width="@dimen/input_icon_size"
                android:layout_height="@dimen/input_icon_size"
                android:contentDescription="Lock icon"
                android:src="@drawable/ic_lock" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/placeholder_text"
                android:textSize="@dimen/input_text_size" />

            <ImageView
                android:id="@+id/btnTogglePassword"
                android:layout_width="@dimen/input_icon_size"
                android:layout_height="@dimen/input_icon_size"
                android:contentDescription="Toggle password visibility"
                android:src="@drawable/ic_visibility_off" />

        </LinearLayout>

        <!-- Password Helper Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/helper_margin_top"
            android:fontFamily="sans-serif"
            android:text="@string/password_helper"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/helper_text_size" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Primary Button "Buat Akun" -->
        <TextView
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/button_margin_top"
            android:background="@drawable/bg_button_primary"
            android:elevation="4dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:stateListAnimator="@null"
            android:text="@string/btn_register"
            android:textColor="@color/text_white"
            android:textSize="@dimen/button_text_size"
            android:textStyle="bold" />

        <!-- Divider "atau" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/divider_margin_vertical"
            android:layout_marginBottom="@dimen/divider_margin_vertical"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/border_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/divider_or"
                android:textColor="@color/text_muted"
                android:textSize="@dimen/label_size" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/border_divider" />

        </LinearLayout>

        <!-- Google Register Button -->
        <LinearLayout
            android:id="@+id/btnGoogleRegister"
            android:layout_width="match_parent"
            android:layout_height="@dimen/social_button_height"
            android:background="@drawable/bg_button_google"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/social_icon_size"
                android:layout_height="@dimen/social_icon_size"
                android:contentDescription="Google icon"
                android:src="@drawable/ic_google" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/btn_google_register"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/social_text_size" />

        </LinearLayout>

        <!-- Terms Text -->
        <TextView
            android:id="@+id/tvTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/terms_text_size" />

        <!-- Spacer to push footer down -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Footer CTA Pill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/footer_margin_top"
            android:background="@drawable/bg_footer_pill"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="@dimen/footer_pill_padding_vertical"
            android:paddingBottom="@dimen/footer_pill_padding_vertical"
            android:paddingStart="@dimen/footer_pill_padding_horizontal"
            android:paddingEnd="@dimen/footer_pill_padding_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/register_footer"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/link_text_size" />

            <TextView
                android:id="@+id/tvGoToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/register_footer_link"
                android:textColor="@color/brand_green"
                android:textSize="@dimen/link_text_size"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
