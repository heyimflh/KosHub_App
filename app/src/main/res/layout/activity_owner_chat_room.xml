<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_screen"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerChatRoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_owner_header_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="10dp"
        android:paddingHorizontal="12dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBackChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_back" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_profile_avatar_circle" />
            <TextView
                android:id="@+id/tvRoomAvatarInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="M"
                android:textColor="@color/brand_green"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoomUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Muhammad Fakhri"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRoomUserStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mahasiswa UNS • Online"
                android:textColor="@color/white_80"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnMoreOptions"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_more" />
    </LinearLayout>

    <!-- Context Card (Booking/Complaint) -->
    <LinearLayout
        android:id="@+id/cardContext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerChatRoom"
        android:layout_margin="12dp"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvContextTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Kos Melati Indah"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvContextSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kamar A-12 • Rp 850.000/bulan"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvContextStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_status_info_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Siap Ambil Kunci"
                android:textColor="@color/status_info_text"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnViewBookingDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_chip_active"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="Detail"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Chat Area -->
    <ScrollView
        android:id="@+id/scrollChat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cardContext"
        android:layout_above="@id/bottomArea"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/messageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingBottom="16dp">
            <!-- Programmatic messages -->
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Area (Quick Actions + Input) -->
    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="16dp"
        android:orientation="vertical">

        <!-- Quick Actions -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:paddingVertical="10dp"
            android:paddingHorizontal="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/quickActionsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/btnTemplatePesan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_inactive_premium"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Template Pesan"
                    android:textColor="@color/brand_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnTerimaBooking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_inactive_premium"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Terima Booking"
                    android:textColor="@color/brand_green"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnTolakBooking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_inactive_premium"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Tolak Booking"
                    android:textColor="@color/home_badge_red"
                    android:textSize="12sp" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Input Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp"
            android:paddingTop="4dp">

            <ImageView
                android:id="@+id/btnAttach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_attach" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_chat"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/owner_chat_room_hint"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnSendMessage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_send" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>