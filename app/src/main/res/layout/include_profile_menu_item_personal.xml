<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/menuPersonal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_profile_menu_item_ripple"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <FrameLayout
        android:layout_width="@dimen/profile_menu_icon_size"
        android:layout_height="@dimen/profile_menu_icon_size"
        android:background="@drawable/bg_profile_menu_icon">

        <ImageView
            android:layout_width="@dimen/profile_menu_icon_inner"
            android:layout_height="@dimen/profile_menu_icon_inner"
            android:layout_gravity="center"
            android:contentDescription="Data Pribadi"
            android:src="@drawable/ic_profile_person" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/profile_menu_personal"
            android:textColor="@color/profile_text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/profile_menu_personal_sub"
            android:textColor="@color/profile_text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:layout_width="@dimen/profile_chevron_size"
        android:layout_height="@dimen/profile_chevron_size"
        android:contentDescription="Arrow"
        android:src="@drawable/ic_profile_chevron_right" />
</LinearLayout>
