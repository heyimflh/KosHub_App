<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootWaitingList"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface">

    <!-- Top Navbar -->
    <LinearLayout
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/md_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/home_padding_horizontal"
        android:paddingEnd="@dimen/home_padding_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_logo_koshub" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:text="@string/home_brand"
            android:textColor="@color/brand_green"
            android:textSize="20sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btnNotification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notif_button"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell" />
        </FrameLayout>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollWaitingList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/bottomNav"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Page Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/waiting_page_title"
                    android:textColor="@color/md_on_surface"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:text="Pantau antreanmu dan amankan kamar segera setelah tersedia."
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Guide Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_waiting_info_card"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_waiting_queue"
                    app:tint="@color/brand_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sistem Antrean Otomatis"
                        android:textColor="@color/md_on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kami akan memberi tahu giliranmu via notifikasi. Pastikan HP aktif!"
                        android:textColor="@color/md_on_surface_variant"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Needs Action -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-medium"
                android:text="Perlu Tindakan Segera"
                android:textColor="@color/md_tertiary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <include layout="@layout/include_waiting_available_card" />

            <!-- Section: Active Queue -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-medium"
                android:text="Antrean yang Sedang Berjalan"
                android:textColor="@color/md_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <include layout="@layout/include_waiting_status_card" />

            <include layout="@layout/include_waiting_timeline" />

            <!-- Section: Next Steps -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-medium"
                android:text="Bantuan &amp; Tindakan"
                android:textColor="@color/md_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <include layout="@layout/include_waiting_next_step" />

            <!-- Footer Info -->
            <include layout="@layout/include_waiting_info_card" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav_standard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_nav_height"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
