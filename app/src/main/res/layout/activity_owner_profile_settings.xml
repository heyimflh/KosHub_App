<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/owner_background"
    android:fitsSystemWindows="true">

    <!-- Bottom Navigation -->
    <include layout="@layout/layout_owner_bottom_nav" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/ownerBottomNav"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== A. HEADER PROFILE SECTION ===== -->
            <RelativeLayout
                android:id="@+id/profileHeaderSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_owner_header_gradient"
                android:paddingTop="32dp"
                android:paddingBottom="48dp">

                <!-- Back Button -->
                <FrameLayout
                    android:id="@+id/btnBackProfile"
                    android:layout_width="@dimen/owner_notif_btn_size"
                    android:layout_height="@dimen/owner_notif_btn_size"
                    android:layout_marginStart="@dimen/owner_padding_horizontal"
                    android:background="@drawable/bg_owner_notif_btn"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/waiting_cancel_negative"
                        android:src="@drawable/ic_arrow_back" />
                </FrameLayout>

                <!-- Edit Button -->
                <FrameLayout
                    android:id="@+id/btnEditProfileOwner"
                    android:layout_width="@dimen/owner_notif_btn_size"
                    android:layout_height="@dimen/owner_notif_btn_size"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="@dimen/owner_padding_horizontal"
                    android:background="@drawable/bg_owner_notif_btn"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:contentDescription="Edit"
                        android:src="@drawable/ic_profile_edit" />
                </FrameLayout>

                <!-- Avatar + Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_profile_avatar_circle">
                        <ImageView
                            android:id="@+id/imgOwnerAvatar"
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:layout_gravity="center"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_profile_person" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvOwnerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/owner_greeting"
                        android:textColor="@color/owner_text_white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOwnerEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.85"
                        android:text="ahmad.mitra@koshub.com"
                        android:textColor="@color/owner_text_white"
                        android:textSize="14sp" />

                    <!-- Verification Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_owner_badge_verified"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_profile_verified"
                            app:tint="@color/owner_badge_verified_text" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/owner_badge_verified"
                            android:textColor="@color/owner_badge_verified_text"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-24dp"
                android:orientation="vertical"
                android:paddingStart="@dimen/owner_padding_horizontal"
                android:paddingEnd="@dimen/owner_padding_horizontal"
                android:paddingBottom="32dp">

                <!-- ===== B. PROFILE COMPLETION CARD ===== -->
                <LinearLayout
                    android:id="@+id/cardOwnerCompletion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_owner_card"
                    android:elevation="@dimen/owner_card_elevation"
                    android:orientation="vertical"
                    android:padding="@dimen/owner_card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="Kelengkapan Data Bisnis"
                            android:textColor="@color/owner_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvOwnerProfileCompletion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/brand_green"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressOwnerCompletion"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/owner_progress_height"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/bg_owner_progress_bar" />

                    <TextView
                        android:id="@+id/btnCompleteLegal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_profile_completion_cta"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="Lengkapi Dokumen Legal"
                        android:textColor="@color/brand_green"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ===== C. QUICK STATS GRID (2x2) ===== -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/owner_section_spacing"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- Total Kos -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_owner_stat_card"
                        android:elevation="2dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvOwnerKosCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/owner_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/owner_stat_total_kos"
                            android:textColor="@color/owner_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Hunian -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_owner_stat_card"
                        android:elevation="2dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvOwnerHunian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/brand_green"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hunian"
                            android:textColor="@color/owner_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Booking -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_owner_stat_card"
                        android:elevation="2dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvOwnerBookingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/owner_stat_booking_accent"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Booking"
                            android:textColor="@color/owner_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Revenue -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_owner_stat_card"
                        android:elevation="2dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvOwnerRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="@color/owner_stat_revenue_accent"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Revenue"
                            android:textColor="@color/owner_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </GridLayout>

                <!-- ===== D. MENU CATEGORY: BUSINESS ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="MANAJEMEN BISNIS"
                    android:textColor="@color/owner_text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_owner_card"
                    android:elevation="1dp"
                    android:orientation="vertical">

                    <!-- Menu: Legalitas -->
                    <LinearLayout
                        android:id="@+id/menuOwnerLegal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_owner_menu_ripple"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_profile_document"
                            app:tint="@color/brand_green" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Dokumen Legalitas"
                                android:textColor="@color/owner_text_primary"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SIUP, TDP, dan IMB Properti"
                                android:textColor="@color/owner_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_owner_chevron_right" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="54dp" android:background="@color/owner_divider" />

                    <!-- Menu: Metode Pembayaran -->
                    <LinearLayout
                        android:id="@+id/menuOwnerPayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_owner_menu_ripple"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_profile_payment"
                            app:tint="@color/brand_green" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Metode Pencairan"
                                android:textColor="@color/owner_text_primary"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rekening bank &amp; e-wallet"
                                android:textColor="@color/owner_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_owner_chevron_right" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== E. MENU CATEGORY: SETTINGS ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="PENGATURAN"
                    android:textColor="@color/owner_text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_owner_card"
                    android:elevation="1dp"
                    android:orientation="vertical">

                    <!-- Security -->
                    <LinearLayout
                        android:id="@+id/menuOwnerSecurity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_owner_menu_ripple"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/brand_green" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/profile_menu_settings"
                                android:textColor="@color/owner_text_primary"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Password &amp; Biometrik"
                                android:textColor="@color/owner_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_owner_chevron_right" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="54dp" android:background="@color/owner_divider" />

                    <!-- Help -->
                    <LinearLayout
                        android:id="@+id/menuOwnerHelp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_owner_menu_ripple"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_profile_help"
                            app:tint="@color/brand_green" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/profile_menu_help"
                                android:textColor="@color/owner_text_primary"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hubungi CS KosHub 24/7"
                                android:textColor="@color/owner_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_owner_chevron_right" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== LOGOUT ===== -->
                <LinearLayout
                    android:id="@+id/btnLogoutOwner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_profile_logout_btn"
                    android:clickable="true"
                    android:elevation="1dp"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_profile_logout" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/profile_menu_logout"
                        android:textColor="@color/profile_logout_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
