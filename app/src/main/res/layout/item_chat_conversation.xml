<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Avatar Section -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp">
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_profile_avatar_circle" />
        <TextView
            android:id="@+id/tvAvatarInitial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="M"
            android:textColor="@color/brand_green"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Info Section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Name and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="Muhammad Fakhri"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvChatTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="10.24"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Kos and Kamar -->
        <TextView
            android:id="@+id/tvKosKamar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Kos Melati Indah • A-12"
            android:textColor="@color/brand_green"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Message and Unread Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvLastMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Apakah kunci bisa diambil sore ini?"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvUnreadBadge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_unread_badge"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvBookingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_owner_booking_accepted"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="Siap Ambil Kunci"
            android:textColor="@color/owner_booking_accepted_text"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>
