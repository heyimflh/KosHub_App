<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootMapPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <!-- Navbar (Same as Home) -->
    <LinearLayout
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/home_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/home_padding_horizontal"
        android:paddingEnd="@dimen/home_padding_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_logo_koshub" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:text="@string/home_brand"
            android:textColor="@color/brand_green"
            android:textSize="20sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btnNotification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notif_button"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell" />
        </FrameLayout>
    </LinearLayout>

    <!-- Map Canvas (Remaining Space) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/bottomNav">

        <include layout="@layout/include_map_canvas" />

        <!-- Floating Search/Filter overlay (Below Navbar) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <include layout="@layout/include_map_search_bar" />
        </FrameLayout>

        <!-- Floating Property Card (Above bottom nav) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="@dimen/map_card_margin_horizontal"
            android:layout_marginEnd="@dimen/map_card_margin_horizontal"
            android:layout_marginBottom="16dp">

            <include layout="@layout/include_map_property_card" />
        </FrameLayout>

    </FrameLayout>

    <!-- Bottom Navigation Bar (Fixed bottom) -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav_standard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_nav_height"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
