<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_owner_menu_ripple"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="4dp"
    android:layout_marginBottom="8dp">

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_owner_action_icon">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="Kos"
            android:src="@drawable/ic_owner_building" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvPropertyName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Nama Properti"
                android:textColor="@color/owner_text_primary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvPropertyStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_owner_property_active"
                android:text="AKTIF"
                android:textColor="@color/owner_property_active_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvPropertyAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Alamat • X kamar"
            android:textColor="@color/owner_text_muted"
            android:textSize="11sp" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:contentDescription="Rating"
                android:src="@drawable/ic_owner_star" />
            <TextView
                android:id="@+id/tvPropertyRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="4.8"
                android:textColor="@color/owner_text_secondary"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/tvPropertyRooms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="3 kamar tersedia"
                android:textColor="@color/owner_stat_revenue_accent"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="Detail"
        android:src="@drawable/ic_owner_chevron_right" />
</LinearLayout>
