<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih Kos"
            android:textColor="@color/owner_text_primary"
            android:textStyle="bold"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerKosPromo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_owner_mini_card" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nama Promo"
            android:textColor="@color/owner_text_primary"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etPromoName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_owner_mini_card"
            android:hint="Misal: Promo Lebaran"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Persentase Diskon (%)"
            android:textColor="@color/owner_text_primary"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etPromoDiscount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_owner_mini_card"
            android:hint="1-99"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Mulai"
                    android:textColor="@color/owner_text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etPromoStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_owner_mini_card"
                    android:focusable="false"
                    android:clickable="true"
                    android:hint="Pilih tanggal"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Berakhir"
                    android:textColor="@color/owner_text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etPromoEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_owner_mini_card"
                    android:focusable="false"
                    android:clickable="true"
                    android:hint="Pilih tanggal"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Deskripsi Promo (Opsional)"
            android:textColor="@color/owner_text_primary"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etPromoDescription"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_owner_mini_card"
            android:gravity="top"
            android:hint="Detail promo..."
            android:padding="12dp"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
