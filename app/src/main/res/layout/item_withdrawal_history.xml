<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvWithdrawAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 2.000.000"
            android:textColor="@color/finance_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWithdrawDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20 Mei 2026 • Transfer Bank"
            android:textColor="@color/finance_text_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvWithdrawStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_finance_status_pending"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="Diproses"
        android:textColor="@color/finance_pending_orange"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
