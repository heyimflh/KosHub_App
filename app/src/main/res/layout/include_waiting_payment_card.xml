<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardPayment"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginTop="16dp"
    android:background="@drawable/bg_waiting_card_elevated"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="20dp"
    android:visibility="gone">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="Payment"
            android:src="@drawable/ic_waiting_payment" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="Pembayaran"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPaymentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_waiting_badge_active"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="Menunggu"
            android:textColor="@color/md_primary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Amount -->
    <TextView
        android:id="@+id/tvPaymentAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="Rp 500.000"
        android:textColor="@color/md_on_surface"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"
        android:text="Deposit konfirmasi booking"
        android:textColor="@color/md_on_surface_variant"
        android:textSize="13sp" />

    <!-- Deadline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_waiting_info_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="Deadline"
            android:src="@drawable/ic_waiting_schedule" />

        <TextView
            android:id="@+id/tvPaymentDeadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:text="Konfirmasi dalam 24 jam"
            android:textColor="@color/md_on_surface_variant"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Pay Button -->
    <TextView
        android:id="@+id/btnPay"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_waiting_btn_pay"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="💳 Bayar Sekarang"
        android:textColor="@color/md_on_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
