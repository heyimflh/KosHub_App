<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/home_card_white"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="Dokumen Legalitas"
            android:textColor="@color/home_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btnCancelLegal"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_notif_button"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textColor="@color/home_text_secondary"
                android:textSize="16sp" />
        </FrameLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/home_border" />

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/imgDocPreview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerInside"
                android:src="@drawable/bg_map_placeholder"
                android:layout_marginBottom="16dp" />

            <!-- KTP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kartu Tanda Penduduk (KTP)"
                    android:textColor="@color/home_text_dark"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvKtpStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum Diupload"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnUploadKTP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Upload KTP"
                android:textAllCaps="false"
                android:backgroundTint="@color/brand_green" />

            <!-- SKU/SIUP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SKU / SIUP Bisnis"
                    android:textColor="@color/home_text_dark"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSkuStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum Diupload"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnUploadSKU"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Upload SKU/SIUP"
                android:textAllCaps="false"
                android:backgroundTint="@color/brand_green" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
