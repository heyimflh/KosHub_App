<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Section Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/detail_section_fasilitas"
        android:textColor="@color/md_on_surface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Grid-like flow for Amenities -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/amenityChipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="10dp"
        app:chipSpacingVertical="10dp">

        <!-- Individual chips will be added programmatically or styled better -->
    </com.google.android.material.chip.ChipGroup>

</LinearLayout>
