<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/queueTimelineContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginTop="16dp"
    android:background="@drawable/bg_waiting_card_elevated"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Section Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Status Antrean"
        android:textColor="@color/md_on_surface"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Step 1: Masuk Waiting List (DONE) -->
    <LinearLayout
        android:id="@+id/stepWaitingList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="top"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_waiting_timeline_dot_done" />

            <View
                android:layout_width="2dp"
                android:layout_height="28dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_waiting_timeline_line_done" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Masuk Waiting List"
                android:textColor="@color/md_on_surface"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:text="Kamu terdaftar di antrean"
                android:textColor="@color/md_on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Done"
            android:src="@drawable/ic_waiting_check_circle" />
    </LinearLayout>

    <!-- Step 2: Menunggu Kamar (ACTIVE) -->
    <LinearLayout
        android:id="@+id/stepAvailability"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="top"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_waiting_timeline_dot_active" />

            <View
                android:layout_width="2dp"
                android:layout_height="28dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_waiting_timeline_line_pending" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Menunggu Kamar Tersedia"
                android:textColor="@color/md_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:text="Sedang menunggu ketersediaan"
                android:textColor="@color/md_on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Active"
            android:src="@drawable/ic_waiting_schedule" />
    </LinearLayout>

    <!-- Step 3: Konfirmasi Pemilik (PENDING) -->
    <LinearLayout
        android:id="@+id/stepOwnerConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="top"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_waiting_timeline_dot_pending" />

            <View
                android:layout_width="2dp"
                android:layout_height="28dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_waiting_timeline_line_pending" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="Konfirmasi Pemilik"
                android:textColor="@color/md_outline"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:text="Pemilik mengkonfirmasi booking"
                android:textColor="@color/md_outline"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Step 4: Pembayaran (PENDING) -->
    <LinearLayout
        android:id="@+id/stepPayment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="top"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_waiting_timeline_dot_pending" />

            <View
                android:layout_width="2dp"
                android:layout_height="28dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_waiting_timeline_line_pending" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="Pembayaran"
                android:textColor="@color/md_outline"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:text="Bayar untuk konfirmasi booking"
                android:textColor="@color/md_outline"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Step 5: Selesai (PENDING) -->
    <LinearLayout
        android:id="@+id/stepCompleted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="top"
        android:orientation="horizontal">

        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_waiting_timeline_dot_pending" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="Selesai"
                android:textColor="@color/md_outline"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:text="Kamar siap ditempati"
                android:textColor="@color/md_outline"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
