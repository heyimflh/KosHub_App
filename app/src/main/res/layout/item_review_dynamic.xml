<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_white_border"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Avatar + Name Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Avatar Circle -->
        <FrameLayout
            android:id="@+id/reviewAvatarFrame"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_circle">

            <TextView
                android:id="@+id/tvReviewAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/md_on_secondary_container"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Name + Sub -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReviewName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/md_on_surface"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvReviewSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md_on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Review Text -->
    <TextView
        android:id="@+id/tvReviewText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/md_on_surface_variant"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.5" />
</LinearLayout>