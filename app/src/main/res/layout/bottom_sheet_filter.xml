<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/home_card_white"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="@string/home_filter_title"
            android:textColor="@color/home_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btnCloseFilter"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_notif_button"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textColor="@color/home_text_secondary"
                android:textSize="16sp" />
        </FrameLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/home_border" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Sort -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/home_filter_sort"
            android:textColor="@color/home_text_dark"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerSort"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_bar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <!-- Rentang Harga -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:text="Rentang Harga"
            android:textColor="@color/home_text_dark"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.slider.RangeSlider
            android:id="@+id/rangeSliderHarga"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:valueFrom="300000"
            android:valueTo="3000000"
            android:stepSize="100000"
            app:values="@array/initial_price_range"
            app:thumbColor="@color/brand_green"
            app:trackColorActive="@color/brand_green" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/tvHargaMin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rp 300.000"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tvHargaMax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 3.000.000"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/home_filter_type"
            android:textColor="@color/home_text_dark"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipFilterPutra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="Putra"
                android:textColor="@color/home_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipFilterPutri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="Putri"
                android:textColor="@color/home_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipFilterCampur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="Campur"
                android:textColor="@color/home_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Facilities -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/home_filter_facility"
            android:textColor="@color/home_text_dark"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipFilterWifi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="WiFi"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipFilterAC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="AC"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipFilterKamarMandi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="K. Mandi Dalam"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipFilterParkir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="Parkir"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chipFilterLaundry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_quick_chip_inactive"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="Laundry"
                android:textColor="@color/home_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Apply Button -->
        <TextView
            android:id="@+id/btnApplyFilter"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/home_filter_apply"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Reset Button -->
        <TextView
            android:id="@+id/btnResetFilter"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/home_filter_reset"
            android:textColor="@color/brand_green"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
