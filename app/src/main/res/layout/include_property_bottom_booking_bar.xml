<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@color/md_surface_container_lowest"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Border Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="-16dp"
        android:background="@color/md_outline_variant" />

    <!-- Price Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Left: Price -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detail_price_label"
                android:textColor="@color/md_on_surface_variant"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:baselineAligned="true"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDetailPriceValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/detail_price_value"
                    android:textColor="@color/md_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_price_period"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right: Sisa Kamar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/detail_sisa_kamar"
            android:textColor="@color/md_surface_tint"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Kabari Saya Button -->
        <TextView
            android:id="@+id/btnWaitlistBottom"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_outline_button"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/detail_btn_waitlist"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp" />

        <!-- Booking Sekarang Button -->
        <TextView
            android:id="@+id/btnBookingBottom"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_button"
            android:elevation="4dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/detail_btn_booking"
            android:textColor="@color/md_on_primary"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
