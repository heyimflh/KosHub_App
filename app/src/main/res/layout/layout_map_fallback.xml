<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface_container"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_map_pin"
        android:alpha="0.5"
        android:contentDescription="Map missing" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/map_fallback_title"
        android:textColor="@color/md_on_surface"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvMapFallbackSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/map_fallback_sub"
        android:textColor="@color/md_on_surface_variant"
        android:textSize="14sp" />

</LinearLayout>
