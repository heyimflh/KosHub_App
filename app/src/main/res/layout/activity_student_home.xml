<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <!-- Navbar (Static/Top) -->
    <LinearLayout
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/home_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/home_padding_horizontal"
        android:paddingEnd="@dimen/home_padding_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_logo_koshub" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:text="@string/home_brand"
            android:textColor="@color/brand_green"
            android:textSize="20sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btnNotification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notif_button"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell" />

            <TextView
                android:id="@+id/tvNotifBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_notif_badge"
                android:gravity="center"
                android:textColor="@color/text_white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/navbar"
        android:layout_above="@id/bottomNav"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/home_padding_horizontal"
                android:paddingEnd="@dimen/home_padding_horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/home_search_height"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="@dimen/home_search_icon"
                        android:layout_height="@dimen/home_search_icon"
                        android:src="@drawable/ic_search" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="@string/home_search_hint"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/home_text_dark"
                        android:textColorHint="@color/home_text_placeholder"
                        android:textSize="14sp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnFilter"
                    android:layout_width="@dimen/home_filter_btn_size"
                    android:layout_height="@dimen/home_filter_btn_size"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_filter_btn"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_sliders" />
                </FrameLayout>
            </LinearLayout>

            <!-- Quick Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/home_padding_horizontal"
                android:paddingEnd="@dimen/home_padding_horizontal"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipSemua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_quick_chip_active"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/home_chip_semua"
                        android:textColor="@color/text_white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipPutra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_quick_chip_inactive"
                        app:drawableStartCompat="@drawable/ic_school"
                        android:drawablePadding="6dp"
                        app:drawableTint="@color/home_text_secondary"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:text="@string/home_chip_putra"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipPutri"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_quick_chip_inactive"
                        app:drawableStartCompat="@drawable/ic_school"
                        android:drawablePadding="6dp"
                        app:drawableTint="@color/home_text_secondary"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:text="@string/home_chip_putri"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/chipCampur"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_quick_chip_inactive"
                        app:drawableStartCompat="@drawable/ic_domain"
                        android:drawablePadding="6dp"
                        app:drawableTint="@color/home_text_secondary"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:text="@string/home_chip_campur"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- View Toggle & Result Count -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:paddingStart="@dimen/home_padding_horizontal"
                android:paddingEnd="@dimen/home_padding_horizontal">

                <LinearLayout
                    android:id="@+id/toggleContainerHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:background="@drawable/bg_toggle_container"
                    android:orientation="horizontal"
                    android:padding="@dimen/home_toggle_padding">

                    <TextView
                        android:id="@+id/btnFeedView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_toggle_active"
                        android:fontFamily="sans-serif-black"
                        android:paddingStart="24dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="10dp"
                        android:text="@string/home_feed_view"
                        android:textColor="@color/text_white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btnMapView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_toggle_inactive"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="24dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="10dp"
                        android:text="@string/home_map_view"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Section Label -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:paddingStart="@dimen/home_padding_horizontal"
                android:paddingEnd="@dimen/home_padding_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/home_section_label"
                    android:textColor="@color/home_text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvResultCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="10 kos"
                    android:textColor="@color/home_text_muted"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- Main Scrollable List -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvKosList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:paddingStart="@dimen/home_padding_horizontal"
                    android:paddingEnd="@dimen/home_padding_horizontal"
                    android:paddingBottom="16dp" />

                <LinearLayout
                    android:id="@+id/layoutEmptyStateHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:alpha="0.5"
                        android:src="@drawable/ic_school" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Tidak ada kos ditemukan"
                        android:textColor="@color/home_text_muted"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Coba ubah kata kunci atau filter kamu."
                        android:textColor="@color/home_text_muted"
                        android:alpha="0.7"
                        android:textSize="13sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="32dp"
                    android:visibility="gone" />
            </RelativeLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav_standard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_nav_height"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
