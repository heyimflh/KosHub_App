<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootPropertyDetail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface">

    <!-- Scrollable Main Content -->
    <ScrollView
        android:id="@+id/scrollPropertyDetail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="160dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Image Section -->
            <include layout="@layout/include_property_hero" />

            <!-- Content Sections with padding -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp">

                <!-- Title + Badges + Location -->
                <include layout="@layout/include_property_title" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:background="@color/md_outline_variant" />

                <!-- Amenities Grid -->
                <include layout="@layout/include_property_amenities" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:background="@color/md_outline_variant" />

                <!-- Description -->
                <include layout="@layout/include_property_description" />

                <!-- Spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <!-- Location & Access -->
                <include layout="@layout/include_property_location" />

                <!-- Spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <!-- Reviews -->
                <include layout="@layout/include_property_reviews" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Floating Top Navigation (overlay) -->
    <include layout="@layout/include_property_top_nav" />

    <!-- Sticky Bottom Booking Bar (overlay) -->
    <include layout="@layout/include_property_bottom_booking_bar" />

</FrameLayout>
