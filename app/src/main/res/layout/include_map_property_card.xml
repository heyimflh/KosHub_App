<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/routeCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_map_property_card"
    android:elevation="@dimen/map_card_elevation"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true">

    <!-- Card Content Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/map_card_padding">

        <!-- Kos Image -->
        <ImageView
            android:id="@+id/imgKosCard"
            android:layout_width="@dimen/map_card_image_size"
            android:layout_height="@dimen/map_card_image_size"
            android:background="@drawable/bg_map_card_image_radius"
            android:scaleType="centerCrop"
            android:contentDescription="Kos image" />

        <!-- Text Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- Kos Name -->
            <TextView
                android:id="@+id/tvKosName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="@string/map_card_kos_name"
                android:textColor="@color/md_on_surface"
                android:textSize="@dimen/map_card_title_size" />

            <!-- Address (Restored) -->
            <TextView
                android:id="@+id/tvKosAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif"
                android:maxLines="1"
                android:text="Jl. Mawar No. 17, Kebumen"
                android:textColor="@color/md_on_surface_variant"
                android:textSize="12sp" />

            <!-- Distance -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_map_location_on"
                    android:contentDescription="Location" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="sans-serif"
                    android:text="@string/map_card_kos_distance"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="@dimen/map_card_subtitle_size" />

            </LinearLayout>

            <!-- Price -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/map_card_kos_price"
                    android:textColor="@color/md_primary"
                    android:textSize="@dimen/map_card_price_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/map_card_kos_price_period"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/map_card_padding"
        android:paddingEnd="@dimen/map_card_padding"
        android:paddingBottom="@dimen/map_card_padding">

        <TextView
            android:id="@+id/btnViewDetail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/map_card_btn_height"
            android:background="@drawable/bg_map_card_btn_detail"
            android:elevation="2dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/map_card_btn_detail"
            android:textColor="@color/md_on_primary"
            android:textSize="@dimen/map_card_btn_text_size"
            android:clickable="true"
            android:focusable="true" />

    </FrameLayout>

</LinearLayout>
